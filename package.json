{
  "name": "chzzk-vod-downloader",
  "version": "3.0.0",
  "description": "Chzzk VOD/Clip downloader with search, segment download, and browser extension support",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "ffmpeg-static": "^5.2.0"
  },
  "build": {
    "appId": "com.chzzk.voddownloader",
    "productName": "Chzzk VOD Downloader",
    "win": {
      "target": "nsis",
      "icon": "src/media/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*"
    ],
    "files": [
      "src/**/*",
      "resources/**/*"
    ]
  }
}
